{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Prism Configuration",
    "type": "object",
    "properties": {
        "project_name": {
            "type": "string"
        },
        "theme_preset": {
            "type": "string",
            "enum": [
                "clinical",
                "clinical-precision",
                "clinical-lab",
                "clinical-sport",
                "playful",
                "playful-paws",
                "playful-boing",
                "playful-threads",
                "luxury",
                "luxury-noir",
                "luxury-velvet",
                "luxury-atelier",
                "organic",
                "organic-moss",
                "organic-apothecary",
                "organic-farmstead",
                "eco",
                "eco-clean-minimal",
                "eco-kraft"
            ]
        },
        "compliance_mode": {
            "type": "string",
            "enum": [
                "none",
                "supplements",
                "pet_food",
                "cosmetic",
                "eco",
                "tech",
                "food"
            ]
        },
        "brand_colors": {
            "type": "object",
            "properties": {
                "primary": {
                    "type": "string"
                },
                "secondary": {
                    "type": "string"
                }
            }
        },
        "niche": {
            "type": "object",
            "properties": []
        }
    },
    "required": [
        "project_name",
        "theme_preset",
        "compliance_mode",
        "brand_colors"
    ]
}